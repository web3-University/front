{
  "name": "web3-school-dapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "biome check",
    "format": "biome format --write",
    "type-check": "tsc --noEmit",
    "test:unit": "jest",
    "test:unit:ci": "jest --coverage --watchAll=false --ci --passWithNoTests",
    "test:e2e": "cypress open",
    "test:e2e:ci": "cypress run --headless --browser chrome",
    "prepare": "husky install",
    "lint:staged": "lint-staged"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx}": [
      "biome format --write"
    ],
    "src/**/*.{css,scss,less}": [
      "biome format --write"
    ],
    "*.{json,md}": [
      "biome format --write"
    ]
  },
  "dependencies": {
    "@biomejs/biome": "^2.2.4",
    "@rainbow-me/rainbowkit": "^2.2.8",
    "@tanstack/react-query": "^5.90.2",
    "axios": "^1.12.2",
    "clsx": "^2.1.1",
    "immer": "^10.1.3",
    "lucide-react": "^0.544.0",
    "next": "15.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "viem": "^2.37.8",
    "wagmi": "^2.17.5",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@jest/globals": "30.0.5",
    "@swc/core": "1.13.3",
    "@swc/jest": "^0.2.39",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "6.8.0",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cypress": "15.2.0",
    "husky": "9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "30.1.3",
    "jest-environment-jsdom": "30.1.2",
    "jest-stare": "2.5.2",
    "jest-transform-stub": "^2.0.0",
    "lint-staged": "16.1.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
